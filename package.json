{
  "name": "narrative-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && node build-server.mjs && electron-builder --win"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "idb-keyval": "^6.2.2",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^3.0.0",
    "concurrently": "^9.2.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.aidm.mainapp",
    "productName": "AI DM",
    "files": [
      "dist/**",
      "electron/**",
      "server.bundle.cjs",
      "public/**",
      "!data/**",
      "!release/**",
      "!.exe/**"
    ],
    "asarUnpack": [
      "server.bundle.cjs"
    ],
    "directories": {
      "output": "build-output"
    },
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "asar": true
  }
}
